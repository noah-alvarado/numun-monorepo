{{define "_layout"}}<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{.Subject}}</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f5;font-family:Helvetica,Arial,sans-serif;color:#222;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4f4f5;padding:24px 0;">
    <tr><td align="center">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="background:#ffffff;border-radius:6px;overflow:hidden;">
        <tr><td style="background:{{.BrandColor}};padding:20px 32px;">
          <a href="{{.PortalBaseURL}}" style="text-decoration:none;color:#ffffff;font-size:20px;font-weight:600;letter-spacing:0.3px;">NUMUN</a>
        </td></tr>
        <tr><td style="padding:32px;font-size:15px;line-height:1.55;">
          {{template "body" .}}
          <p style="margin:32px 0 0 0;color:#777;font-size:13px;">Sent {{.NowFormatted}}.</p>
        </td></tr>
        <tr><td style="padding:20px 32px;background:#fafafa;color:#777;font-size:12px;border-top:1px solid #e5e5e5;">
          <p style="margin:0;">NUMUN &mdash; Northwestern University Model United Nations</p>
          {{if .UnsubscribeURL}}<p style="margin:8px 0 0 0;"><a href="{{.UnsubscribeURL}}" style="color:#777;">Unsubscribe from announcements</a></p>{{end}}
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
{{end}}
