{{define "subject"}}Payment recorded for your NUMUN delegation{{end}}
{{define "body"}}
<p>Hi{{with .RecipientName}} {{.}}{{end}},</p>
<p>A {{index .Vars "kind"}} of <strong>{{index .Vars "amountFormatted"}}</strong> has been recorded for <strong>{{index .Vars "delegationName"}}</strong>.</p>
<p>New balance due: <strong>{{index .Vars "newBalanceFormatted"}}</strong></p>
{{with index .Vars "notes"}}<p style="background:#fafafa;padding:12px 16px;border-left:3px solid {{$.BrandColor}};margin:16px 0;"><em>Note:</em> {{.}}</p>{{end}}
<p>View the full ledger in the portal: <a href="{{.PortalBaseURL}}/delegation">{{.PortalBaseURL}}/delegation</a></p>
{{end}}
