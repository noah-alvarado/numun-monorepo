---
// Site-wide layout. Reads SEO defaults from /content/config/seo-defaults.md
// at build time and applies per-page `seo` overrides when present.
//
// CMS images: Decap writes paths like `/uploads/<...>` that resolve at
// runtime relative to the site origin. We render those via plain <img>
// tags (no build-time optimization since the binaries aren't bundled).
// Upgrade path: if we host originals on a CDN/CMS and want Astro to
// optimize them at build, configure `image.remotePatterns` in
// astro.config.mjs and switch to `<Image src={remoteUrl} ...>` per
// https://docs.astro.build/en/guides/images/#using-images-from-a-cms-or-cdn

import { getEntry } from "astro:content";

// Global Tailwind v4 stylesheet (preflight + utilities + brand tokens).
// Pulled in via a side-effect import so Astro emits a single CSS bundle
// linked from every page that uses this layout.
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  canonicalPath?: string;
}

const { title, description, ogImage, noindex, canonicalPath } = Astro.props;

const defaults = await getEntry("seo-defaults", "seo-defaults");
const siteTitle = defaults?.data.siteTitle ?? "NUMUN";
const siteDescription =
  defaults?.data.siteDescription ?? "Northwestern University Model UN";
const themeColor = defaults?.data.themeColor ?? "#4E2A84";
const defaultOgImage = defaults?.data.defaultOgImage;

const resolvedTitle = title ? `${title} · ${siteTitle}` : siteTitle;
const resolvedDescription = description ?? siteDescription;
const resolvedOg = ogImage ?? defaultOgImage;
const canonical = canonicalPath
  ? new URL(canonicalPath, Astro.site).toString()
  : Astro.url.toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content={themeColor} />
    <!--
      Northwestern-blessed web typefaces from the brand guidelines:
        - IBM Plex Sans → Akkurat Pro substitute, body sans (Tailwind `font-sans`)
        - Poppins       → headlines / subheads on the web (Tailwind `font-display`)
        - Noto Serif    → body text on the web (Tailwind `font-serif`)
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&family=Noto+Serif:wght@400;700&display=swap"
    />
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {resolvedOg && <meta property="og:image" content={resolvedOg} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    {resolvedOg && <meta name="twitter:image" content={resolvedOg} />}
  </head>
  <!--
    Body default is the serif stack (Periódico / Noto Serif) per
    Northwestern's typography guidance: "Periódico Text… meant to be used
    for longer chunks of copy at smaller sizes." Headlines opt into
    `font-display` / `font-sans` (Poppins / Campton) explicitly.
  -->
  <body class="bg-white text-nu-black-800 font-serif">
    <slot />
  </body>
</html>
