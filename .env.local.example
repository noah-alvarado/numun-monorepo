# Local-dev env contract for the NUMUN portal/API.
# Copy to .env.local and adjust as needed.
#
# This file mirrors what SAM Local injects via scripts/sam-env-vars.json.
# Use it for direct `go run` / `pnpm dev` invocations outside SAM.

# --- General ---
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- Service endpoints (LocalStack + DDB Local) ---
AWS_ENDPOINT_URL_DYNAMODB=http://localhost:8000
AWS_ENDPOINT_URL_S3=http://localhost:4566
AWS_ENDPOINT_URL_SES=http://localhost:4566
AWS_ENDPOINT_URL_SQS=http://localhost:4566
AWS_ENDPOINT_URL_SNS=http://localhost:4566

# --- Tables / buckets / queues ---
DDB_TABLE_NAME=numun-test
UPLOADS_BUCKET_NAME=numun-test-uploads
S3_ARTIFACTS_BUCKET=numun-org-artifacts
S3_ASSETS_BUCKET=numun-org-assets
SQS_EMAIL_SEND_URL=http://localhost:4566/000000000000/numun-prod-email-send
SNS_EMAIL_FEEDBACK_ARN=arn:aws:sns:us-east-2:000000000000:numun-prod-email-feedback

# --- Cognito (unused locally; present for parity) ---
COGNITO_USER_POOL_ID=local-pool
COGNITO_CLIENT_ID=local-client

# --- SES sender identities ---
SES_FROM_NOREPLY=noreply@mail.numun.org
SES_FROM_ANNOUNCEMENTS=announcements@mail.numun.org
SES_FROM_COGNITO=cognito@mail.numun.org

# --- MailHog (when running outside SAM/LocalStack) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Dev-only auth bypass (NEVER set in prod) ---
DEV_MODE=true
DEV_BYPASS_AUTH=true

# --- Local HTTP mode (skip Lambda adapter for `go run ./cmd/api`) ---
LOCAL_HTTP=true

# --- Portal Vite env ---
VITE_API_BASE_URL=http://localhost:3000
