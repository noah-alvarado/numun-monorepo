# Portal build-time environment variables. Vite inlines `VITE_*` values into
# the built bundle, so they must be set at build time, not runtime.
#
# Copy this file to `.env.local` for local development; CI passes the same
# variables via the test GitHub environment in .github/workflows/portal.yml.

# Connect transport target. Local dev defaults to http://localhost:3000.
# Production builds override per environment (e.g. https://api.test.numun.org).
VITE_API_BASE_URL=http://localhost:3000

# Cognito wiring. Leave empty for the DEV_BYPASS_AUTH path; the portal's
# cognito.ts module short-circuits when these are unset.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Set to "true" to short-circuit the Cognito SDK calls in the portal and
# accept seed-user UUIDs in the email field on /sign-in.
VITE_DEV_BYPASS=true

# Set to a seed user UUID to attach X-Dev-User-Id on every Connect call.
# Used for the "always signed-in" dev experience (no need to go through
# sign-in screens). See /docs/seed-users.md.
VITE_DEV_USER_ID=
